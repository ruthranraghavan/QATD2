{
    "mcp": {
        "servers": {
            "atlassian": {
                "command": "npx",
                "args": [
                    "-y",
                    "@atlassian/mcp-atlassian",
                    "--transport",
                    "stdio"
                ],
                "env": {
                    "JIRA_URL": "YOUR_JIRA_URL",
                    "JIRA_USERNAME": "YOUR_JIRA_USERNAME",
                    "JIRA_API_TOKEN": "YOUR_JIRA_API_TOKEN"
                }
            },
            "playwright": {
                "command": "npx",
                "args": [
                    "-y",
                    "@playwright/mcp@latest",
                    "--output-dir",
                    "/tmp/playwright-mcp",
                    "--user-data-dir",
                    "/Users/hnai/Library/Application Support/playwright-mcp"
                ]
            },
            "filesystem": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "/Users/hnai/Desktop/qa-training-testometer-day-2",
                    "/Users/hnai/Downloads"
                ]
            },
            "github": {
                "command": "npx",
                "args": ["-y", "@modelcontextprotocol/server-github@latest"],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
                }
            }
        }
    }
}